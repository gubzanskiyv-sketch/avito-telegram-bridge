# Telegram: токен от @BotFather и ID/имя канала.
TELEGRAM_BOT_TOKEN=123456789:replace_me
TELEGRAM_CHAT_ID=@your_channel

# Случайная длинная строка. Она становится частью URL webhook.
WEBHOOK_SECRET=replace_with_at_least_32_random_characters
PUBLIC_WEBHOOK_BASE_URL=https://example.ru

# Подписи профилей в уведомлениях: Avito user_id -> понятное название.
PROFILE_NAMES_JSON={"111111111":"Профиль 1","222222222":"Профиль 2","333333333":"Профиль 3"}

# Данные API каждого профиля. Не публикуйте настоящий файл .env.
AVITO_ACCOUNTS_JSON=[{"name":"Профиль 1","client_id":"replace_me","client_secret":"replace_me"},{"name":"Профиль 2","client_id":"replace_me","client_secret":"replace_me"},{"name":"Профиль 3","client_id":"replace_me","client_secret":"replace_me"}]

HOST=0.0.0.0
PORT=8080
FORWARD_OUTGOING=false

